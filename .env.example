# ─── Polygon.io ───────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here

# ─── AWS ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ─── Anthropic (Claude API) ────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── App environment ──────────────────────────────────────────
STOCVEST_ENV=development      # development | staging | production

# ─── Redis (ElastiCache — local dev uses localhost) ────────────
REDIS_URL=redis://localhost:6379

# ─── DynamoDB (local dev can point to DynamoDB Local) ─────────
DYNAMODB_ENDPOINT_URL=        # leave blank in production; set to http://localhost:8000 locally

# ─── Broker sandbox integration harness (Phase 3f) ─────────────
STOCVEST_ENABLE_SANDBOX_INTEGRATION=0
STOCVEST_IBKR_GATEWAY=
STOCVEST_ETRADE_GATEWAY=
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=

# ─── Cognito JWT authorizer (Phase 4b) ───────────────────────────
COGNITO_USER_POOL_ID=
COGNITO_REGION=
COGNITO_APP_CLIENT_ID=

# ─── WebSocket connection registry (Phase 4g hardening) ───────────
STOCVEST_WS_CONNECTIONS_TABLE=
STOCVEST_WS_CONNECTION_TTL_SECONDS=86400

# ─── Trade Journal + PDT persistence (Phase 5 hardening) ───────────
STOCVEST_TRADE_JOURNAL_TABLE=
STOCVEST_PDT_STATE_TABLE=
