# ─── Polygon.io ───────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here

# ─── AWS ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ─── Anthropic (Claude API) ────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── App environment ──────────────────────────────────────────
STOCVEST_ENV=development      # development | staging | production

# ─── Redis (ElastiCache — local dev uses localhost) ────────────
REDIS_URL=redis://localhost:6379

# ─── DynamoDB (local dev can point to DynamoDB Local) ─────────
DYNAMODB_ENDPOINT_URL=        # leave blank in production; set to http://localhost:8000 locally
