# --- Local development ---
NEXT_PUBLIC_STOCVEST_API_BASE_URL=http://localhost:3001
# Optional: preferred for Next.js Server Components — avoids localhost when NEXT_PUBLIC_* is missing at runtime.
STOCVEST_API_BASE_URL=http://localhost:3001
STOCVEST_AUTH_COOKIE_NAME=stocvest_auth_token

# --- Vercel (Production + Preview) — copy from Terraform outputs (infra/) ---
# terraform output -raw api_gateway_http_invoke_url
# Set BOTH below to the same API Gateway URL (no trailing slash).

# NEXT_PUBLIC_STOCVEST_API_BASE_URL=https://xxxx.execute-api.us-east-1.amazonaws.com
# STOCVEST_API_BASE_URL=https://xxxx.execute-api.us-east-1.amazonaws.com

# terraform output -raw api_gateway_websocket_callback_url  (includes /$default stage path)
# NEXT_PUBLIC_STOCVEST_WS_URL=wss://....execute-api.us-east-1.amazonaws.com/$default

# terraform output -raw cognito_user_pool_id
# NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxx

# terraform output -raw cognito_user_pool_client_frontend_id
# NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Paid marketing / checkout (default off until payments are live) ---
# NEXT_PUBLIC_ENABLE_PAID_CHECKOUT=true

# --- Crisp chat (beta feedback) — Website ID from https://app.crisp.chat/ ---
# NEXT_PUBLIC_CRISP_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
