aws_region = "REPLACE_WITH_AWS_REGION"

aws_account_id = "REPLACE_WITH_AWS_ACCOUNT_ID"

vpc_cidr_block = "10.20.0.0/16"

public_subnet_cidr_blocks = [
  "10.20.1.0/24",
  "10.20.2.0/24"
]

private_subnet_cidr_blocks = [
  "10.20.11.0/24",
  "10.20.12.0/24"
]

availability_zones = [
  "REPLACE_WITH_AZ_1",
  "REPLACE_WITH_AZ_2"
]

allowed_ingress_cidrs = [
  "0.0.0.0/0"
]

# Phase 6f — optional JWT overrides for HTTP API (leave empty to use Cognito from Terraform)
cognito_jwt_issuer   = ""
cognito_jwt_audience = ""

# Signal analysis: internal header auth for GET /v1/signals/analysis (set a real secret locally; never commit terraform.tfvars).
# internal_analysis_key = "REPLACE_WITH_ROTATED_SECRET"

# Optional: HTTP API stage throttling ($default). Omitted = Terraform variable defaults (2000 RPS / 4000 burst).
# Example (strict): http_api_throttling_rate_limit = 100, http_api_throttling_burst_limit = 200
# http_api_throttling_rate_limit  = 1000
# http_api_throttling_burst_limit = 2000
