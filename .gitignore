# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual envs
.venv/
venv/
env/

# Secrets — NEVER commit these
.env
*.env
!.env.example

# pytest
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Frontend
frontend/node_modules/
frontend/.next/
frontend/build-out.txt
frontend/.env.local
*.tsbuildinfo
# Stray root-level node_modules (e.g. from running `npm install` from the
# repo root by accident) — keep it out of version control even though the
# canonical install path is frontend/.
/node_modules/

# AWS / Terraform (for later phases)
*.tfstate
*.tfstate.backup
.terraform/
infra/terraform.tfvars
infra/backend.hcl
infra/.terraform_placeholder_lambda.zip
infra/tfplan
*.tfplan

# Ops/debug artifacts (local Lambda invokes, error dumps — do not commit)
infra/*-out.json
infra/*-errors.json
infra/lambda-payload-*.json
infra/maturation-*.json
infra/md-errors.json
infra/brokers-*.json
infra/scanner-*.json
infra/watchlist-symbols-out.json
vitest-summary.log

# Local ledger verification reports (generated — keep on disk, do not commit)
reports/ledger/*
!reports/ledger/.gitkeep
